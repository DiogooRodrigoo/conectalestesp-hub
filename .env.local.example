# =============================================================================
# Conecta Leste SP — Hub
# Variáveis de Ambiente
#
# INSTRUCOES:
#   1. Copie este arquivo: cp .env.local.example .env.local
#   2. Preencha os valores abaixo
#   3. NUNCA commite o arquivo .env.local no git
#   4. Em produção, configure essas variáveis no painel da Vercel
#      (vercel.com > Project > Settings > Environment Variables)
#
# SEGURANCA:
#   • Variáveis com NEXT_PUBLIC_ são expostas no bundle do browser
#   • Variáveis SEM NEXT_PUBLIC_ existem apenas no servidor (server-side)
#   • NUNCA coloque secrets (service_role, API keys privadas) em NEXT_PUBLIC_*
# =============================================================================

# -----------------------------------------------------------------------------
# SUPABASE — banco compartilhado com o Marque Já
# O Hub usa o MESMO projeto Supabase do Marque Já.
# As tabelas do Hub (clients, leads, payments) foram adicionadas ao mesmo banco
# via migration 004 e 005.
# Onde encontrar: supabase.com > Projeto Marque Já > Settings > API
# -----------------------------------------------------------------------------

# URL pública do projeto Supabase (a mesma do Marque Já)
NEXT_PUBLIC_SUPABASE_URL=https://xyshrrgogkqguofpneie.supabase.co

# Chave anônima (seguro expor no browser — acesso limitado por RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Chave de Service Role — APENAS SERVER-SIDE, NUNCA no browser
# PERIGO: Essa chave bypassa o RLS e tem acesso total ao banco
# Usar somente em API Routes que precisam provisionar clientes
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# -----------------------------------------------------------------------------
# APLICACAO
# -----------------------------------------------------------------------------

# URL pública da aplicação (sem barra no final)
# Desenvolvimento: http://localhost:3001
# Produção: https://hub.conectalestemsp.com.br (ou seu domínio)
NEXT_PUBLIC_APP_URL=http://localhost:3001

# -----------------------------------------------------------------------------
# GOOGLE MAPS / PLACES API (módulo de prospecção de leads)
# Onde encontrar: console.cloud.google.com > APIs & Services > Credentials
# RESTRICAO DE SEGURANCA: Restringir a chave ao domínio de produção no console
# do Google Cloud para evitar uso não autorizado
# -----------------------------------------------------------------------------

# Chave da Google Places API (usada no servidor para buscar comércios)
# NÃO usar NEXT_PUBLIC_ — chamadas à API do Google devem ser proxy'd pelo servidor
GOOGLE_PLACES_API_KEY=AIzaSy...

# -----------------------------------------------------------------------------
# MONITORAMENTO (opcional mas recomendado em producao)
# -----------------------------------------------------------------------------

# Sentry DSN para captura de erros em produção
# Onde encontrar: sentry.io > Seu Projeto > Settings > Client Keys (DSN)
# NEXT_PUBLIC_SENTRY_DSN=https://xxxxxxxx@oxxxxxxx.ingest.sentry.io/xxxxxxx

# Auth Token do Sentry para upload de source maps no build
# SENTRY_AUTH_TOKEN=sntrys_...
